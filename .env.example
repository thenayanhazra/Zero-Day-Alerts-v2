# Application
ENV=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/zero_day_alerts

# Queue / cache
REDIS_URL=redis://localhost:6379/0

# External API keys
NVD_API_KEY=replace-me
CISA_API_KEY=replace-me
GITHUB_TOKEN=replace-me

# Webhooks / alert sinks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/replace/me
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/replace/me
PAGERDUTY_ROUTING_KEY=replace-me
